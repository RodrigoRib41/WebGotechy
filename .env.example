# ============================================================
#  GoTechy — Variables de entorno
#  Copiá este archivo a `.env` y completá con tus valores.
#  Las variables con prefijo VITE_ son expuestas al cliente.
#  Después de modificar .env hay que reiniciar `npm run dev`.
# ============================================================

# --- SUPABASE ---------------------------------------------------
# Obtenelas en https://app.supabase.com/project/_/settings/api
# Project URL: SIN trailing slash, SIN /rest/v1
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# --- CLOUDINARY -------------------------------------------------
# Cloud name: https://console.cloudinary.com/console (top right)
# Upload preset: Settings → Upload → Add upload preset (Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=gotechy-blog

# --- DATOS DE CONTACTO (mostrados en el sitio) ------------------
# Teléfono visible para el usuario (formato libre).
VITE_CONTACT_PHONE=+54 9 11 6753-3991

# Número de WhatsApp: solo dígitos con código de país (sin +, sin espacios).
# Usado para los links wa.me. Si lo dejás vacío, se usa VITE_CONTACT_PHONE.
VITE_WHATSAPP_NUMBER=5491167533991

# Email de contacto.
VITE_CONTACT_EMAIL=contacto@gotechy.com

# --- SITIO (opcional) -------------------------------------------
VITE_SITE_URL=http://localhost:5173
